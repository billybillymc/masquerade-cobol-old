{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "masquerade/policy-routing-decision.schema.json",
  "title": "PolicyRoutingDecision",
  "type": "object",
  "required": [
    "request_id",
    "tenant_id",
    "workload_classification",
    "selected_mode",
    "policy_template",
    "reason_codes",
    "audit_required"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "workload_classification": {
      "type": "string",
      "enum": ["sensitive", "proprietary", "standard", "public"]
    },
    "selected_mode": {
      "type": "string",
      "enum": ["external", "local_private"]
    },
    "policy_template": {
      "type": "string",
      "enum": ["standard-external", "sensitive-local", "custom"]
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "audit_required": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
