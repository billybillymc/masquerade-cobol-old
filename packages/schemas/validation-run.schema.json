{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "masquerade/validation-run.schema.json",
  "title": "ValidationRunResult",
  "type": "object",
  "required": [
    "run_id",
    "module_id",
    "mode",
    "strict_numeric_emulation_passed",
    "high_assurance_ready",
    "non_actionable",
    "summary",
    "mismatches",
    "confidence_inputs"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "module_id": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "enum": ["migration_ready", "sandbox"] },
    "strict_numeric_emulation_passed": { "type": "boolean" },
    "high_assurance_ready": { "type": "boolean" },
    "non_actionable": { "type": "boolean" },
    "summary": {
      "type": "object",
      "required": ["total_cases", "pass_count", "fail_count", "diff_pass_rate"],
      "properties": {
        "total_cases": { "type": "integer", "minimum": 0 },
        "pass_count": { "type": "integer", "minimum": 0 },
        "fail_count": { "type": "integer", "minimum": 0 },
        "diff_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "mismatches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "class", "severity"],
        "properties": {
          "case_id": { "type": "string" },
          "class": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "confidence_inputs": {
      "type": "object",
      "required": ["numeric_semantics_score", "behavioral_match_score"],
      "properties": {
        "numeric_semantics_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "behavioral_match_score": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
